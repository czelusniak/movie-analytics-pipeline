# Copy this file to .env and fill in any values you need.
# .env is git-ignored — never commit real credentials.

# Path to the DuckDB warehouse (relative to project root)
DUCKDB_PATH=data/warehouse.duckdb

# Path to raw CSV files
RAW_DATA_DIR=data/raw

# Superset secret key — change this if deploying outside localhost
SUPERSET_SECRET_KEY=change-me-in-production
